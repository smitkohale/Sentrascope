# ============================================================
# SentraScope — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below
# 3. At minimum set: DATABASE_URL, SESSION_SECRET
# ============================================================

# ── Server ports ─────────────────────────────────────────────
PORT=8080
# API_SERVER_PORT=8080   (used by the frontend Vite proxy)

# ── App URL (used in email links) ────────────────────────────
# Local dev default — change to your domain in production
APP_URL=http://localhost:5173

# ── Database — Supabase (required) ───────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Supabase dashboard → Project Settings → Database → Connection string
# 3. Copy the "Direct connection" URI (port 5432, not the pooler 6543)
#    It looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# 4. Paste it below, then run database/supabase-init.sql in the Supabase SQL editor
#    (Supabase dashboard → SQL Editor → New query) to create the users + alert_settings tables.
# NOTE: if the password contains special characters (@, /, :, etc.), URL-encode them
# (e.g. @ → %40, / → %2F) or postgres.js will fail to parse the connection string.
DATABASE_URL=

# ── Supabase project keys (required for Supabase) ─────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Backend-only — keep secret, never expose to the frontend
SUPABASE_SERVICE_ROLE_KEY=

# ── JWT Secret (required) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── WAQI — Air Quality (optional) ────────────────────────────
# Free key: https://aqicn.org/api/
# Without this, AQI uses the WAQI "demo" token (limited data)
WAQI_API_TOKEN=

# ── NASA FIRMS — Fire/Thermal Hotspots (optional) ─────────────
# Free key: https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_MAP_KEY=

# ── OpenUV — UV Index (optional) ──────────────────────────────
# Free tier: https://www.openuv.io/ (50 req/day)
OPENUV_API_KEY=

# ── India OGD — CPCB Data (optional) ──────────────────────────
# Free key: https://data.gov.in/
INDIA_OGD_API_KEY=

# ── Brevo — Email Delivery (optional) ────────────────────────
# Free: https://brevo.com (300 emails/day)
# Without this, email links are printed to the server console log instead
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=

# ── Google Earth Engine — Urbanization (optional) ─────────────
# Requires service account: https://earthengine.google.com
# Paste the full JSON key as a single line — leave blank to disable
GEE_SERVICE_ACCOUNT_KEY=
GEE_PROJECT_ID=
