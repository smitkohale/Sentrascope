# ============================================================
# SentraScope — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below
# 3. At minimum set: DATABASE_URL, SESSION_SECRET
# ============================================================

# ── Server ports ─────────────────────────────────────────────
PORT=8080
# API_SERVER_PORT=8080   (used by the frontend Vite proxy)

# ── App URL (used in email links) ────────────────────────────
# Local dev default — change to your domain in production
APP_URL=http://localhost:5173

# ── Database (required) ───────────────────────────────────────
# If using docker compose (recommended):
DATABASE_URL=
# Custom Postgres:
# DATABASE_URL=postgresql://neondb_owner:npg_MTZ4UB3GqpAn@ep-fragrant-voice-a1yi6fg9-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── JWT Secret (required) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── WAQI — Air Quality (optional) ────────────────────────────
# Free key: https://aqicn.org/api/
# Without this, AQI uses the WAQI "demo" token (limited data)
WAQI_API_TOKEN=

# ── NASA FIRMS — Fire/Thermal Hotspots (optional) ─────────────
# Free key: https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_MAP_KEY=

# ── OpenUV — UV Index (optional) ──────────────────────────────
# Free tier: https://www.openuv.io/ (50 req/day)
OPENUV_API_KEY=

# ── India OGD — CPCB Data (optional) ──────────────────────────
# Free key: https://data.gov.in/
INDIA_OGD_API_KEY=

# ── Brevo — Email Delivery (optional) ────────────────────────
# Free: https://brevo.com (300 emails/day)
# Without this, email links are printed to the server console log instead
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=

# ── Google Earth Engine — Urbanization (optional) ─────────────
# Requires service account: https://earthengine.google.com
# Paste the full JSON key as a single line — leave blank to disable
GEE_SERVICE_ACCOUNT_KEY=
GEE_PROJECT_ID=
